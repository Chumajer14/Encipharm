APP_NAME="Enci Ventas API"
APP_ENV=development
APP_VERSION=1.0.0
ENABLE_TEMPORARY_ROLE_SWITCHER=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:5175","http://127.0.0.1:5173","http://127.0.0.1:5174","http://127.0.0.1:5175","https://enciapp.vercel.app"]
# Optional regex for preview deployments. Keep empty unless needed.
CORS_ORIGIN_REGEX=^https://enciapp-[a-z0-9-]+-chumajer14s-projects\.vercel\.app$
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Firebase web config used by http://localhost:8000/docs
FIREBASE_WEB_API_KEY=your-firebase-api-key
FIREBASE_WEB_AUTH_DOMAIN=your-auth-domain
FIREBASE_WEB_STORAGE_BUCKET=your-storage-bucket
FIREBASE_WEB_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_WEB_APP_ID=your-app-id
FIREBASE_WEB_MEASUREMENT_ID=your-measurement-id

# UAT/go-live checks
# GET /readiness debe responder status=ready antes de abrir UAT o produccion.
